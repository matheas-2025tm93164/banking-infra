        {
          "expr": "sum(increase(transactions_total{job=\"transaction-service\"}[$__range]))",
          "refId": "A",
          "legendFormat": "transactions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "noValue": "0"
